<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <!-- 应用图标 -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="24dp" />

    <!-- 应用名称 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="呆呆面板"
        android:textSize="28sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- 版本号 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v0.0.1"
        android:textSize="14sp"
        android:textColor="#999999"
        android:layout_marginBottom="32dp" />

    <!-- 状态文本 -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="正在检查环境..."
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp" />

    <!-- 依赖检查列表 -->
    <LinearLayout
        android:id="@+id/check_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <!-- Python -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/python_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Python 运行时"
                android:textSize="14sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/python_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查中..."
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <!-- Node.js -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#F5F5F5">

            <ImageView
                android:id="@+id/node_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Node.js 运行时"
                android:textSize="14sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/node_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查中..."
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>
    </LinearLayout>

    <!-- 下载进度区域 -->
    <LinearLayout
        android:id="@+id/download_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/download_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在下载..."
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/download_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/download_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_gravity="end"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 启动面板按钮 -->
        <Button
            android:id="@+id/start_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="启动面板"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/holo_blue_dark"
            android:visibility="gone" />

        <!-- 下载按钮 -->
        <Button
            android:id="@+id/download_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="下载运行时"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:visibility="gone" />

        <!-- 本地导入按钮 -->
        <Button
            android:id="@+id/import_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="本地导入运行时"
            android:textSize="16sp"
            android:textColor="#666666"
            android:background="#E0E0E0"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- 跳过按钮 -->
        <Button
            android:id="@+id/skip_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳过，直接启动"
            android:textSize="14sp"
            android:textColor="#999999"
            android:background="?android:attr/selectableItemBackground"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
